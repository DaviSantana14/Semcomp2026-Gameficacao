DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password
DB_SCHEMA=public
JWT_SECRET=your_jwt_secret

# Frontend autorizado no CORS.
# Local:
FRONTEND_URL=http://localhost:3000

# Politica do cookie de auth.
# Local/dev:
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# Teste rapido com Vercel + Render ou Netlify + Render:
# FRONTEND_URL=https://seu-front.vercel.app
# FRONTEND_URL=https://seu-front.netlify.app
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true

# Producao final em mesmo site/dominio controlado:
# FRONTEND_URL=https://semcomp.com.br
# COOKIE_SAME_SITE=lax
# COOKIE_SECURE=true
